set shell := ["bash", "-cu"]

# show all available tasks
_default:
  just --justfile ~/_justfile --list

# enable direnv for nixshell
[group('direnv helpers')]
[no-cd]
enable-direnv-for-nixshell:
  @echo "use nix" >> .envrc

# enable direnv for flake
[group('direnv helpers')]
[no-cd]
enable-direnv-for-flake:
  @echo "use flake" >> .envrc

# allow direnv to read environment
[group('direnv helpers')]
[no-cd]
allow:
  @direnv allow


# show all available dev environment templates
[group('dev environments')]
show-all-dev-env-templates:
  @ls -a ~/_dev_envs/

# copy dev env template to current directory
[group('dev environments')]
[no-cd]
copy-dev-env-template template_name destination=".":
  @src="$HOME/_dev_envs/{{template_name}}" && cp -rT --dereference "$src" "{{destination}}"

