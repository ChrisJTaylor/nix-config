# show all available tasks
jefault:
  @just --list

# ensure commands run from project root
set dotenv-load := false
set shell := ["bash", "-cu"]

# Restore dependencies (Cargo takes care of this automatically when building)
restore:
  cargo fetch
  echo "Dependencies fetched."

# Build the project
build:
  cargo build

# Build in release mode
release:
  cargo build --release

# Run the project
run:
  cargo run

# Run with release optimizations
run-release:
  cargo run --release

# Run tests
test:
  cargo test

# run tests with verbose output
test-verbose:
  cargo test -- --nocapture

# run clippy (linter)
lint:
  cargo clippy --all-targets --all-features -- -D warnings

# format the code
fmt:
  cargo fmt --all

# check for formatting issues without changing files
fmt-check:
  cargo fmt --all -- --check

# clean the build output
clean:
  cargo clean

# watch for file changes and re-run tests
watch-tests:
  cargo watch -x test

# watch for file changes and re-run build
watch-build:
  cargo watch -x build

# full CI check
ci:
  just fmt-check
  just lint
  just test-verbose

